# ELDA project configuration — copy to elda.yaml and edit paths

project:
  name: my-board-project
  output_dir: output
  api_url: http://localhost:8000

target:
  soc: your-soc
  arch: arm
  kernel_version: "4.1.15"
  kernel_source: /path/to/linux-bsp
  git_branch: elda/my-board-project
  cross_compile: arm-linux-gnueabihf-

model:
  bailian_api_key: ${BAILIAN_API_KEY}
  deepseek_api_key: ${DEEPSEEK_API_KEY}
  code_model: qwen3-coder-plus
  reasoning_model: deepseek-v4-pro
  bailian_reasoning_model: qwen3-max
  embedding_model: text-embedding-v4

milvus:
  host: localhost
  port: 19530

peripherals:
  - id: sensor_0
    name: my_sensor
    enabled: true
    bus: spi
    driver_framework: iio
    driver_module_path: drivers/iio
    datasheet: docs/sensor.pdf
    function_requirements:
      - read_chip_id
      - init_device
      - read_sensor_data
      - expose_iio
      - generate_test_app
    board:
      spi:
        bus_id: 1
        cs_gpio: GPIO1_IO20
        mode: 0
        max_frequency: 10000000
      gpios:
        reset: GPIO1_IO18
        irq: GPIO1_IO19
      power:
        vcc: 3.3V

board:
  dts: /path/to/linux-bsp/arch/arm/boot/dts/my-board.dts

deploy:
  mode: tftp_nfs_serial
  tftp:
    directory: /srv/tftp
    zimage_name: zImage
    dtb_name: my-board.dtb
  nfs:
    rootfs: /export/nfs/rootfs
    ko_path: root/drivers
    app_path: root/tests
  serial:
    port: /dev/ttyUSB0
    baudrate: 115200

build:
  max_fix_rounds: 10
  auto_apply_patches: true
  targets:
    - module
    - dtc
    - zimage
    - dtb
