# Copy to .env via: bash scripts/init_compose_env.sh
# NEVER commit .env — credentials are generated locally per machine.

ELDA_POSTGRES_USER=elda
ELDA_POSTGRES_PASSWORD=
ELDA_POSTGRES_DB=elda

ELDA_MINIO_ROOT_USER=elda
ELDA_MINIO_ROOT_PASSWORD=
ELDA_MINIO_ACCESS_KEY=
ELDA_MINIO_SECRET_KEY=
ELDA_MINIO_BUCKET=elda-artifacts
ELDA_MINIO_SECURE=false
ELDA_MINIO_ENDPOINT=127.0.0.1:9000

ELDA_REDIS_URL=redis://127.0.0.1:6379/0
ELDA_MILVUS_HOST=127.0.0.1
ELDA_MILVUS_PORT=19530
ELDA_WORKER_START_DELAY=3

ELDA_DATABASE_URL=

# Optional LLM keys (prefer secrets/api_keys.yaml)
# BAILIAN_API_KEY=
# DEEPSEEK_API_KEY=
